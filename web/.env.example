# Copy this file to `.env` and fill in your real project credentials.
# Find these under Project Settings -> API in your Supabase dashboard.
# Until these are set, the app falls back to localStorage so you can still
# preview the shop and admin dashboard.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Demo admin credentials used ONLY when Supabase is not configured above,
# so the admin dashboard can still be previewed without a backend.
VITE_DEMO_ADMIN_EMAIL=admin@rosie.co
VITE_DEMO_ADMIN_PASSWORD=rosie2026

# TODO: Stripe publishable key (for the checkout Payment Element).
# The checkout currently renders a mocked Payment Element with no real
# charges — wire this up when you're ready to accept real payments.
VITE_STRIPE_PUBLISHABLE_KEY=

# Google Places API key. Used for shipping-address autocomplete AND for
# pulling your Google Business reviews into the homepage review section.
# Enable BOTH "Places API" and "Maps JavaScript API" in Google Cloud, turn
# on billing, then restrict the key to your website's domain (HTTP referrer).
VITE_GOOGLE_PLACES_API_KEY=

# Place ID of your Google Business listing (for homepage reviews). Find it
# with Google's Place ID Finder:
# https://developers.google.com/maps/documentation/places/web-service/place-id
# Leave blank to keep the built-in sample reviews. Google returns up to 5.
VITE_GOOGLE_PLACE_ID=
